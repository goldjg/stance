{
  "version": "2.1.0",
  "$schema": "https://json.schemastore.org/sarif-2.1.0.json",
  "runs": [
    {
      "tool": {
        "driver": {
          "name": "STANCE",
          "version": "dev",
          "rules": [
            {
              "id": "TEST-001",
              "name": "First generic posture finding",
              "shortDescription": {
                "text": "Detected failing condition."
              },
              "defaultConfiguration": {
                "level": "warning"
              }
            },
            {
              "id": "TEST-002",
              "name": "Second generic posture finding",
              "shortDescription": {
                "text": "No failing conditions detected."
              },
              "defaultConfiguration": {
                "level": "warning"
              }
            }
          ]
        }
      },
      "results": [
        {
          "ruleId": "TEST-001",
          "level": "warning",
          "message": {
            "text": "Detected failing condition."
          }
        }
      ]
    }
  ]
}
